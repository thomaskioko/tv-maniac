#!/bin/sh
# Tracked pre-commit hook, activated by `git config core.hooksPath scripts/git-hooks`
# (see scripts/install-git-hooks.sh). Points lefthook at git-hooks.yml and runs it.
# Auto-formats staged files; skip a commit with `git commit --no-verify`.
set -eu

ROOT=$(git rev-parse --show-toplevel)
export LEFTHOOK_CONFIG="$ROOT/git-hooks.yml"

if command -v lefthook >/dev/null 2>&1; then
  exec lefthook run pre-commit "$@"
elif [ -x /opt/homebrew/bin/lefthook ]; then
  exec /opt/homebrew/bin/lefthook run pre-commit "$@"
elif [ -x /usr/local/bin/lefthook ]; then
  exec /usr/local/bin/lefthook run pre-commit "$@"
fi

echo "lefthook not found; skipping git hooks (run ./scripts/setup.sh to install)" >&2
