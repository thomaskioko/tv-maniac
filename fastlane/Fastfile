default_platform(:ios)

TEST_DEVICE = "iPhone 16 Pro"
PACKAGE_NAME = "com.thomaskioko.tvmaniac"

platform :ios do

  before_all do
    setup_ci
    ENV["FASTLANE_XCODEBUILD_SETTINGS_TIMEOUT"] = "180"
    ENV["ORG_GRADLE_PROJECT_app_debugOnly"] = "false"
    ENV["ORG_GRADLE_PROJECT_app_enableIos"] = "true"
  end

  desc "Run Snapshot Tests"
  lane :snapshot_tests do
    clear_derived_data_lane

    run_tests(
      project: "ios/tv-maniac.xcodeproj",
      scheme: "SwiftUIComponents",
      destination: "platform=iOS Simulator,OS=18.5,name=#{TEST_DEVICE}",
      clean: true,
      result_bundle: true,
      xcargs: "-retry-tests-on-failure -skipPackagePluginValidation",
      number_of_retries: 2,
      fail_build: true,
      derived_data_path: "derived_data",
      cloned_source_packages_path: "ios/SourcePackages"
    )
  end

  desc "Build iOS App (Debug, simulator)"
  lane :build_tvmaniac do
    sh("xcodebuild -project ../ios/tv-maniac.xcodeproj \
      -scheme tv-maniac \
      -destination 'platform=iOS Simulator,OS=18.5,name=#{TEST_DEVICE}' \
      -configuration Debug \
      -clonedSourcePackagesDirPath ../ios/SourcePackages \
      clean build \
      COMPILER_INDEX_STORE_ENABLE=NO"
    )
  end

  # ---------------------------------------------------------------------------
  # Release lanes
  # ---------------------------------------------------------------------------

  desc "Build and upload to TestFlight"
  lane :build_release do |options|
    clear_derived_data_lane

    api_key = nil
    if ENV["APP_STORE_CONNECT_API_KEY_ID"] && ENV["APP_STORE_CONNECT_ISSUER_ID"] && ENV["APP_STORE_CONNECT_API_KEY"]
      api_key = app_store_connect_api_key(
        key_id: ENV["APP_STORE_CONNECT_API_KEY_ID"],
        issuer_id: ENV["APP_STORE_CONNECT_ISSUER_ID"],
        key_content: ENV["APP_STORE_CONNECT_API_KEY"],
      )
    end

    if ENV["MATCH_GIT_URL"]
      match(
        type: "appstore",
        app_identifier: PACKAGE_NAME,
        git_url: ENV["MATCH_GIT_URL"],
        readonly: true,
        api_key: api_key,
      )
    else
      UI.important("MATCH_GIT_URL not set — skipping certificate download. Build may fail without signing.")
    end

    build_ios_app(
      project: "ios/tv-maniac.xcodeproj",
      scheme: "tv-maniac",
      configuration: "Release",
      export_method: "app-store",
      output_directory: "build",
      output_name: "tv-maniac",
      buildlog_path: "fastlane/logs",
      clean: true,
      derived_data_path: "derived_data",
      cloned_source_packages_path: "ios/SourcePackages",
    )

    if api_key
      upload_to_testflight(
        api_key: api_key,
        skip_waiting_for_build_processing: true,
      )
    else
      UI.important("App Store Connect API key not configured — skipping TestFlight upload.")
    end
  end

  desc "Submit to App Store review"
  lane :deploy_app_store do |options|
    submit = options[:submit_for_review] || ENV["IOS_SUBMIT_FOR_REVIEW"] == "true"

    api_key = app_store_connect_api_key(
      key_id: ENV["APP_STORE_CONNECT_API_KEY_ID"],
      issuer_id: ENV["APP_STORE_CONNECT_ISSUER_ID"],
      key_content: ENV["APP_STORE_CONNECT_API_KEY"],
    )

    deliver(
      api_key: api_key,
      submit_for_review: submit,
      automatic_release: false,
      phased_release: true,
      skip_metadata: true,
      skip_screenshots: true,
    )
  end

  # ---------------------------------------------------------------------------
  # Utility lanes
  # ---------------------------------------------------------------------------

  desc "Build TvManiac IPA (Debug, simulator)"
  lane :build_tvmaniac_ipa do
    clear_derived_data_lane

    build_ios_app(
      project: "ios/tv-maniac.xcodeproj",
      scheme: "tv-maniac",
      configuration: "Debug",
      destination: "platform=iOS Simulator,OS=18.5,name=#{TEST_DEVICE}",
      derived_data_path: "derived_data",
      cloned_source_packages_path: "ios/SourcePackages",
      xcargs: "-skipPackagePluginValidation -resolvePackageDependencies",
      output_directory: "build",
      output_name: "tv-maniac-debug",
      buildlog_path: "fastlane/logs",
      clean: true,
      skip_package_ipa: true,
      skip_archive: true,
      skip_codesigning: true,
      export_method: "development",
      export_options: {
        method: "development",
        signingStyle: "automatic",
        compileBitcode: false,
        provisioningProfiles: {}
      }
    )
  end

  desc "Clear derived data"
  lane :clear_derived_data_lane do
    clear_derived_data(
      derived_data_path: "derived_data"
    )
  end

  desc "Run SwiftLint"
  lane :lint do
    swiftlint(
      mode: :lint,
      raise_if_swiftlint_error: true,
      config_file: ".swiftlint.yml"
    )
  end

  desc "Format Swift code with SwiftFormat"
  lane :format_swift_code do
    sh "cd .. && swiftformat ios --config .swiftformat --swiftversion 5.9"
  end

  desc "Check Swift code formatting with SwiftFormat"
  lane :check_swift_format do
    sh "cd .. && swiftformat ios --config .swiftformat --lint --swiftversion 5.9"
  end
end

platform :android do

  desc "Deploy AAB to Play Store internal track"
  lane :deploy_play_store do |options|
    supply(
      package_name: PACKAGE_NAME,
      track: "internal",
      aab: "app/build/outputs/bundle/release/app-release.aab",
      json_key_data: ENV["PLAY_STORE_SERVICE_ACCOUNT_JSON"],
      release_status: "completed",
      skip_upload_metadata: true,
      skip_upload_images: true,
      skip_upload_screenshots: true,
    )
  end

  desc "Deploy AAB to Play Store production track (0.1% rollout)"
  lane :deploy_production do |options|
    rollout = options[:rollout] || "0.001"

    supply(
      package_name: PACKAGE_NAME,
      track: "production",
      rollout: rollout,
      aab: "app/build/outputs/bundle/release/app-release.aab",
      json_key_data: ENV["PLAY_STORE_SERVICE_ACCOUNT_JSON"],
      release_status: "inProgress",
      skip_upload_metadata: true,
      skip_upload_images: true,
      skip_upload_screenshots: true,
    )
  end

  desc "Distribute release APK via Firebase App Distribution"
  lane :distribute_alpha do |options|
    groups = options[:groups] || "internal"

    firebase_app_distribution(
      app: ENV["FIREBASE_APP_ID"],
      android_artifact_path: "app/build/outputs/apk/release/app-release.apk",
      service_credentials_file: ENV["FIREBASE_APP_DISTRIBUTION_SA"],
      groups: groups,
      release_notes: changelog_from_git_commits(
        commits_count: 10,
        merge_commit_filtering: "exclude_merges",
      ),
    )
  end

  desc "Promote a release between tracks"
  lane :promote do |options|
    from_track = options[:from] || "internal"
    to_track = options[:to] || "beta"
    rollout = options[:rollout] || "1.0"

    supply(
      package_name: PACKAGE_NAME,
      track: from_track,
      track_promote_to: to_track,
      rollout: rollout,
      json_key_data: ENV["PLAY_STORE_SERVICE_ACCOUNT_JSON"],
      skip_upload_metadata: true,
      skip_upload_images: true,
      skip_upload_screenshots: true,
    )
  end
end
